{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "inputs": [{ "local": "bot" }],
      "commands": ["pip install -r bot/requirements.txt"]
    }
  },
  "deploy": {
    "inputs": [
      { "step": "install" },
      { "local": "bot" }
    ],
    "startCommand": "cd bot && python bot.py"
  }
}
